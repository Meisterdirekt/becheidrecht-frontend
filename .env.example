# ===========================================
# Vorlage für .env.local (lokal / Mitarbeiter)
# ===========================================
# Kopiere diese Datei:  cp .env.example .env.local
# Trage NUR die Werte ein, die dir die Geschäftsführung freigibt.
# Keine API-Keys oder Geheimnisse hier eintragen – die liegen im Vault.
# ===========================================

# Optional: Für Frontend-Entwicklung (Login/Register etc.)
# Nur eintragen, wenn ausdrücklich freigegeben.
# NEXT_PUBLIC_SUPABASE_URL=https://xxxxx.supabase.co
# NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Optional: Für KI-Analyse (lokal ohne Vault oder auf Vercel)
# OPENAI_API_KEY=sk-...
# Auf Vercel: Settings → Environment Variables → OPENAI_API_KEY eintragen (Production).
# Wenn gesetzt, funktioniert die Bescheid-Analyse auch ohne lokalen vault/ Ordner.

# Pflicht für Schreiben-Generator (Tab „Schreiben erstellen”)
# ANTHROPIC_API_KEY=sk-ant-...
# Auf Vercel: ANTHROPIC_API_KEY eintragen, sonst meldet die API „nicht konfiguriert”.

# ===========================================
# Admin-Zugang (Pflicht für /admin Seite)
# ===========================================
# Komma-getrennte Liste von Admin-E-Mail-Adressen
# ADMIN_EMAILS=admin@bescheidrecht.de
# Alternativ: Geheimer Token für Admin-API-Zugriff (Header: x-admin-token)
# ADMIN_SECRET=ein-sicherer-zufallsstring

# ===========================================
# Multi-Agent-System (optional — Graceful Degradation wenn fehlend)
# ===========================================
# AG04 Rechts-Recherche: Sucht BSG/BVerfG-Urteile via Tavily API
# Ohne Key: AG04 gibt leeres Ergebnis zurück, Pipeline läuft weiter
# TAVILY_API_KEY=tvly-...

# AG09/AG10/AG11 Batch-Agenten: Erstellen GitHub Issues (wöchentlicher Cron)
# Ohne Token: Batch-Agenten überspringen, kein Fehler
# GITHUB_TOKEN=ghp_...
# GITHUB_REPO=owner/repo

# Vercel Deployment-Status (AG11/AG16 DevOps/Vercel-Agent)
# VERCEL_TOKEN=...
# VERCEL_PROJECT_ID=prj_...
# VERCEL_TEAM_ID=team_...

# ===========================================
# Cron-Jobs (Pflicht für automatische Updates)
# ===========================================
# Auth-Secret für Cron-Endpunkte (/api/cron/rechts-update, /api/cron/agent-batch)
# CRON_SECRET=ein-sicherer-zufallsstring

# ===========================================
# Payment — Mollie (Pflicht für Zahlungsverarbeitung)
# ===========================================
# Webhook-URL im Mollie Dashboard eintragen:
#   Settings → Website Profiles → [Profil] → Webhook URL
#   → https://bescheidrecht.de/api/mollie/webhook
#
# Testmodus:  test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Live:       live_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# MOLLIE_API_KEY=live_...

# ===========================================
# Rate-Limiting — Upstash Redis (optional, Fallback: In-Memory)
# ===========================================
# UPSTASH_REDIS_REST_URL=https://xxx.upstash.io
# UPSTASH_REDIS_REST_TOKEN=AXxx...

# ===========================================
# Monitoring — Sentry (optional)
# ===========================================
# SENTRY_DSN=https://xxx@o4xxx.ingest.sentry.io/xxx
# NEXT_PUBLIC_SENTRY_DSN=https://xxx@o4xxx.ingest.sentry.io/xxx
# SENTRY_AUTH_TOKEN=sntrys_...
# SENTRY_ORG=bescheidrecht
# SENTRY_PROJECT=bescheidrecht-frontend
# NEXT_PUBLIC_APP_URL=https://bescheidrecht.de
# PAGESPEED_API_KEY=AIza...

# ===========================================
# Firmenadresse (für Angebots-/Rahmenvertrag-Generator)
# ===========================================
# NEXT_PUBLIC_COMPANY_ADDRESS=Musterstr. 1, 12345 Berlin
# NEXT_PUBLIC_COMPANY_TAX_ID=DE123456789
# NEXT_PUBLIC_COMPANY_CITY=Berlin

# ===========================================
# Entwickler-Testmodus (NICHT auf Vercel/Production setzen!)
# ===========================================
# Wenn true: Analysen werden nicht abgezogen (unbegrenzter Testzugang)
# DEV_UNLIMITED_ANALYSES=true
